<div style="background:#0a0a0b;padding:20px;font-family:ui-sans-serif,system-ui,sans-serif;color:#e4e4e4"><!-- BUG REPORT MODAL --><div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9999995;background:#1a1c20;border:1px solid #2a2a2a;border-radius:8px;padding:16px 18px;minWidth:320px;maxWidth:560px;boxShadow:0 6px 24px rgba(0,0,0,0.6);fontFamily:ui-sans-serif"><div style="fontWeight:700;fontSize:14px;marginBottom:8px;color:#4A9EFF">🐛 Report a Bug</div><div style="fontSize:13px;marginBottom:10px;color:#e4e4e4">Describe what broke. Include what you were trying to do, what happened, and what you expected. Commander will see this, and it can also auto-dispatch to Claude for triage.</div><label style="display:block;fontSize:12px;color:#aaa;marginBottom:6px" for="gam-bug-desc">Describe the bug (20-2000 chars):</label><textarea id="gam-bug-desc" style="width:100%;background:#0f1114;color:#e4e4e4;border:1px solid #2a2a2a;borderRadius:4px;padding:8px;fontSize:13px;fontFamily:inherit;rows:7;maxLength:2000" placeholder="I clicked X on the Y page, expected Z, but got W instead."></textarea><div id="gam-bug-counter" style="color:#a0aec0;fontSize:12px;marginTop:6px;minHeight:16px">0 / 2000 (min 20)</div><label style="display:flex;alignItems:center;fontSize:12px;color:#e4e4e4;marginTop:8px"><input type="checkbox" id="gam-bug-snap" checked style="marginRight:6px"> Include debug snapshot (recent actions, current settings, extension version, page URL, browser). Tokens are redacted.</label><div style="display:flex;justifyContent:flex-end;gap:8px;marginTop:12px"><button style="background:#2a2a2a;color:#e4e4e4;border:0;borderRadius:4px;padding:6px 12px;cursor:pointer;fontSize:13px">Cancel</button><button style="background:#4A9EFF;color:#fff;border:0;borderRadius:4px;padding:6px 12px;cursor:pointer;fontSize:13px">Submit</button></div></div><div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);zIndex:9999994"></div></div>

<!-- ASK TEXT MODAL --><div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9999995;background:#1a1c20;color:#e4e4e4;borderRadius:8px;padding:16px 18px;minWidth:320px;maxWidth:520px;boxShadow:0 6px 24px rgba(0,0,0,0.6);fontFamily:ui-sans-serif;role:dialog;aria-modal:true"><div style="fontSize:14px;fontWeight:700;marginBottom:8px;color:#4A9EFF">Confirm action</div><label style="display:block;fontSize:12px;color:#aaa;marginBottom:6px">Reason for removal:</label><input type="text" placeholder="Spam, abuse, off-topic, etc." style="width:100%;background:#0f1114;color:#e4e4e4;border:1px solid #2a2a2a;borderRadius:4px;padding:8px;fontSize:13px;fontFamily:inherit;boxSizing:border-box"><div style="color:#E74C3C;fontSize:12px;marginTop:6px;minHeight:16px"></div><div style="display:flex;justifyContent:flex-end;gap:8px;marginTop:12px"><button style="background:#2a2a2a;color:#e4e4e4;border:0;borderRadius:4px;padding:6px 12px;cursor:pointer;fontSize:13px">Cancel</button><button style="background:#4A9EFF;color:#fff;border:0;borderRadius:4px;padding:6px 12px;cursor:pointer;fontSize:13px">OK</button></div></div><div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);zIndex:9999994"></div></div>

<!-- PARK MODAL --><div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.65);zIndex:10000000;display:flex;alignItems:center;justifyContent:center"><div style="background:#1a202c;color:#e2e8f0;padding:18px 20px;borderRadius:6px;minWidth:380px;maxWidth:520px;border:1px solid #4a5568;role:dialog;aria-modal:true;aria-label:Park for senior review"><div style="fontWeight:600;marginBottom:10px;fontSize:14px">Park User post_id_12345 for senior review</div><label style="display:block;fontSize:11px;color:#a0aec0;marginBottom:4px">Senior review note</label><textarea style="width:100%;padding:6px 8px;background:#0f1419;color:#e2e8f0;border:1px solid #4a5568;borderRadius:4px;fontFamily:inherit;fontSize:12px;rows:4;maxLength:200">needs senior review</textarea><div style="fontSize:11px;color:#a0aec0;marginTop:6px;role:status;aria-live:polite"></div><div style="display:flex;gap:8px;justifyContent:flex-end;marginTop:12px"><button style="background:#2d3748;color:#e2e8f0;border:1px solid #4a5568;padding:6px 12px;borderRadius:4px;cursor:pointer">Cancel</button><button style="background:#4a9eff;color:#fff;border:none;padding:6px 12px;borderRadius:4px;cursor:pointer">⏸ Park</button></div></div></div>

<!-- PRECEDENT MODAL --><div id="gam-precedent-modal" style="position:fixed;inset:0;zIndex:2147483650;background:rgba(0,0,0,0.55);display:flex;alignItems:center;justifyContent:center"><div style="background:#1a202c;color:#e2e8f0;padding:16px;borderRadius:6px;width:min(420px,90vw);border:1px solid #2d3748"><h3 style="margin:0 0 10px;fontSize:14px">Mark as precedent</h3><input type="text" placeholder="Title (required)" style="width:100%;padding:6px;background:#0f1114;color:#e2e8f0;border:1px solid #2d3748;borderRadius:4px;marginBottom:6px"><input type="text" placeholder="Rule reference (optional)" style="width:100%;padding:6px;background:#0f1114;color:#e2e8f0;border:1px solid #2d3748;borderRadius:4px;marginBottom:6px"><textarea placeholder="Reason (optional)" style="width:100%;padding:6px;background:#0f1114;color:#e2e8f0;border:1px solid #2d3748;borderRadius:4px;marginBottom:6px;minHeight:48px;resize:vertical;font:inherit"></textarea><label style="fontSize:11px;color:#a0aec0">Action taken</label><select style="width:100%;padding:6px;background:#0f1114;color:#e2e8f0;border:1px solid #2d3748;borderRadius:4px;marginBottom:8px"><option>APPROVE</option><option>REMOVE</option><option>BAN</option><option>WATCH</option><option>NOTE</option><option>LOCK</option></select><div style="display:flex;gap:6px;justifyContent:flex-end"><button style="background:#2d3748;color:#e2e8f0;border:1px solid #4a5568;padding:6px 12px;borderRadius:4px;cursor:pointer">Cancel</button><button style="background:#4a9eff;color:#fff;border:none;padding:6px 12px;borderRadius:4px;cursor:pointer">Save</button></div></div></div>