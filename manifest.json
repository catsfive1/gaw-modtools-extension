{
  "manifest_version": 3,
  "name": "GAW ModTools",
  "version": "9.5.2",
  "description": "Moderator toolkit for greatawakening.win: Mod Console, shared flags, audit log, Death Row queue, mod-to-mod chat, and self-heal Maintenance routines.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GAW ModTools",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://greatawakening.win/*",
    "https://*.greatawakening.win/*",
    "https://gaw-mod-proxy.gaw-mods-a2f2d0e4.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://greatawakening.win/*",
        "https://*.greatawakening.win/*"
      ],
      "js": [
        "modtools.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self';"
  }
}